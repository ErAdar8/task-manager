# Copy this file to `.env` and fill in values. Never commit `.env`.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Anthropic (Claude) — required for task analysis features
ANTHROPIC_API_KEY=
# When set, overrides all flows (otherwise: execute + testing_understand → Opus, understand → Sonnet — see lib/analysis/resolve-model.ts)
ANTHROPIC_MODEL_OVERRIDE=

# Supabase — required for database + storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / PostgreSQL — point at your Supabase Postgres connection string
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=
SHADOW_DATABASE_URL=
