# Copy this file to `.env` and fill in values. Never commit `.env`.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Anthropic (Claude) — required for task analysis features
ANTHROPIC_API_KEY=
# When set, used for both analysis flows instead of per-flow defaults (see lib/analysis/resolve-model.ts)
ANTHROPIC_MODEL_OVERRIDE=

# Prisma / PostgreSQL (if you use Prisma migrations)
DATABASE_URL=
SHADOW_DATABASE_URL=
